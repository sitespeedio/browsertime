{
  "include": [
    "lib/core/engine/command/**/*",
    "lib/core/engine/context.js",
    "lib/core/engine/commands.js"
  ],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "types",
    "declarationMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
